{
  "manifest_version": 2,
  "name": "Odoo Email Connector",
  "version": "0.6.2",
  "description": "Links Thunderbird emails to Odoo objects. Status bar shows Odoo records, with verify/import/sync actions.",
  "browser_specific_settings": {
    "gecko": {
      "id": "@thunderbird2odoo.bareos.joergsteffens",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "menus",
    "messagesRead",
    "messagesModify",
    "notifications",
    "storage",
    "clipboardWrite"
  ],
  "optional_permissions": ["*://*/*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/odoo-16.png",
    "32": "icons/odoo-32.png",
    "48": "icons/odoo-48.png",
    "96": "icons/odoo-96.png",
    "128": "icons/odoo-128.png"
  }
}
